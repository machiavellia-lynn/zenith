{"nodes": [{"id": "algo_guide_v2_telegram_bot_joker", "label": "Telegram Bot Joker Data Source", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 1.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_yahoo_finance", "label": "Yahoo Finance Close Price Source", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 1.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_eod_summary", "label": "EOD Summary Aggregation Table", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_SRI", "label": "SRI \u2014 SM Relative Intensity Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 3.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Measures how aggressive Smart Money is today vs its 10-day historical average. Used to normalize SM activity relative to its own baseline rather than absolute values."}, {"id": "algo_guide_v2_RPR", "label": "RPR \u2014 Rasio Tekanan Jual Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 3.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "BM = big players selling, not retail participation. RPR > 0.6 triggers UPTHRUST. Corrected from earlier misname as 'retail participation ratio'."}, {"id": "algo_guide_v2_MES", "label": "MES \u2014 Market Efficiency Score Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 3.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Low MES + high SRI = stealth accumulation (price flat despite heavy SM buying)."}, {"id": "algo_guide_v2_VolxGap", "label": "Volx Gap Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 3.4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_ATR", "label": "ATR% \u2014 Average True Range Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 3.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Per-stock volatility normalization. 3% gain in BBCA (3x ATR) is very different from 3% in PADI (<1x ATR). Without ATR both are detected the same."}, {"id": "algo_guide_v2_phase_classification", "label": "Phase Classification Algorithm v2", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ATR-dynamic thresholds make phase detection stock-specific. Decision tree order matters \u2014 first matching phase wins."}, {"id": "algo_guide_v2_phase_SOS", "label": "Phase SOS \u2014 Sign of Strength", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_SPRING", "label": "Phase SPRING \u2014 Coiled Spring", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_UPTHRUST", "label": "Phase UPTHRUST \u2014 Bull Trap", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_DISTRI", "label": "Phase DISTRI \u2014 Distribution", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_ABSORB", "label": "Phase ABSORB \u2014 Absorption/Stealth Accumulation", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_ACCUM", "label": "Phase ACCUM \u2014 Accumulation", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_phase_NEUTRAL", "label": "Phase NEUTRAL", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "algo_guide_v2_backtest_engine", "label": "Backtest Engine v2 \u2014 Multi-Entry Pair-Based", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-entry: every BUY opens new position, SELL closes all simultaneously. Entry at OPEN of next day (realistic: trader sees signal at night, buys next morning). Replaced single-entry backtest."}, {"id": "algo_guide_v2_profit_factor", "label": "Profit Factor Metric", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "source_location": "Section 7.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaced Expectancy because PF is more intuitive: for every Rp1 lost, how much Rp is gained?"}, {"id": "algo_guide_v2_RSM", "label": "RSM \u2014 SM Ratio Percentage", "file_type": "document", "source_file": "ZENITH_ALGORITHM_GUIDE_v2.md", "so