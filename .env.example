# ═══════════════════════════════════════════════════════════════════════
# ZENITH — environment variables (copy to .env and fill in)
# ═══════════════════════════════════════════════════════════════════════
#
# Generate strong random values:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# ── REQUIRED ───────────────────────────────────────────────────────────

# Flask session signing key. Must be at least 32 characters.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET=CHANGE_ME_generate_a_long_random_string_here_at_least_32_chars

# Login password for /  (the "ACCESS KEY" on the login screen).
# Minimum 8 characters.
ACCESS_KEY=CHANGE_ME_your_login_password

# Admin secret for /admin/* routes (upload-db, pull-db, scraper-*, etc.).
# Minimum 16 characters. Different from ACCESS_KEY.
# NOTE: for backward compat the old env var name `UPLOAD_SECRET` is still
# accepted, but prefer `ADMIN_SECRET` going forward.
ADMIN_SECRET=CHANGE_ME_admin_secret_at_least_16_chars

# Path to SQLite DB file.
DB_PATH=/data/zenith.db

# ── OPTIONAL ───────────────────────────────────────────────────────────

# Separate kill-switch secret for /admin/darurat-nuke-db.
# Defaults to ADMIN_SECRET if not set.
# NUKE_SECRET=CHANGE_ME_rare_use_nuke_secret

# Public URL to a DB snapshot (for /admin/pull-db). Leave empty to disable.
# DROPBOX_DB_URL=https://www.dropbox.com/scl/fi/xxxxx/zenith.db?rlkey=xxxx&dl=1

# Max date-range per API query (days). Defaults to 180.
# MAX_QUERY_RANGE_DAYS=180

# Path to the Telegram session file (without .session suffix).
# TG_SESSION_PATH=/data/session_joker

# Disable scraper worker (e.g. when running a read-only instance).
# SCRAPER_ENABLED=0

# Where to write the scraper lock file. Defaults to /data.
# SCRAPER_LOCK_DIR=/data

# ── LOCAL DEVELOPMENT ONLY ─────────────────────────────────────────────

# Mark local dev; allows missing FLASK_SECRET / ACCESS_KEY with ephemeral values.
# Never set this in production.
# ZENITH_DEV=1

# Allow insecure (non-HTTPS) session cookies for local http://localhost dev.
# Never set this in production.
# COOKIE_INSECURE=1

# Enable Flask debug mode. NEVER in production (leaks stack traces).
# FLASK_DEBUG=1
